# --- Треугольник Паскаля (5 строк через массив) ---
pascal = array(15);
# Строка 0: 1
pascal[0] = 1;
print pascal[0];

# Строка 1: 1 1
pascal[1] = 1;
pascal[2] = 1;

# Строка 2: 1 2 1
pascal[3] = 1;
pascal[4] = pascal[1] + pascal[2];
pascal[5] = 1;

# Строка 3: 1 3 3 1
pascal[6] = 1;
pascal[7] = pascal[3] + pascal[4];
pascal[8] = pascal[4] + pascal[5];
pascal[9] = 1;

# Строка 4: 1 4 6 4 1
pascal[10] = 1;
pascal[11] = pascal[6] + pascal[7];
pascal[12] = pascal[7] + pascal[8];
pascal[13] = pascal[8] + pascal[9];
pascal[14] = 1;

print "Треугольник Паскаля (строка 4):";
print pascal[10];
print pascal[11];
print pascal[12];
print pascal[13];
print pascal[14];

# --- Степени двойки через цикл и проверку ---
print "Степени двойки до 1024:";
power_val = 1;
while (power_val <= 1024) {
    print power_val;
    power_val = power_val * 2;
}

# --- Сложная функция: комбинаторное число C(n,k) = n! / (k! * (n-k)!) ---
func combination(n, k) {
    return factorial(n) / (factorial(k) * factorial(n - k));
}

print "C(5,2):";
print combination(5, 2);
print "C(10,3):";
print combination(10, 3);
print "C(6,3):";
print combination(6, 3);

