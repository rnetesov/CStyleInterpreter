# ================================================================
# БЛОК 1: Математические алгоритмы с вложенными структурами
# ================================================================

print "=== БЛОК 1: Математические алгоритмы ===";

# --- Наибольший общий делитель (алгоритм Евклида) ---
func gcd(a, b) {
    while (b > 0) {
        temp = a;
        # a = b, b = temp % b (через вычитание, т.к. нет оператора %)
        a = b;
        # Вычисляем остаток от деления: temp - floor(temp/b) * b
        b = temp - floor(temp / b) * b;
    }
    return a;
}

print "GCD(48, 18):";
print gcd(48, 18);

print "GCD(100, 75):";
print gcd(100, 75);

print "GCD(17, 13):";
print gcd(17, 13);

# --- Наименьшее общее кратное ---
func lcm(a, b) {
    return a * b / gcd(a, b);
}

print "LCM(12, 18):";
print lcm(12, 18);

# --- Проверка простого числа ---
func is_prime(n) {
    if (n < 2) {
        return 0;
    }
    i = 2;
    while (i * i <= n) {
        remainder = n - floor(n / i) * i;
        if (remainder == 0) {
            return 0;
        }
        i++;
    }
    return 1;
}

print "Простые числа до 30:";
for (n = 2; n <= 30; n++) {
    if (is_prime(n) == 1) {
        print n;
    }
}

# --- Числа Фибоначчи через функцию с массивом ---
func fib(count) {
    if (count < 1) {
        return 0;
    }
    a = 0;
    b = 1;
    result = 0;
    for (i = 0; i < count; i++) {
        result = a;
        temp = a + b;
        a = b;
        b = temp;
    }
    return result;
}

print "Fib(10):";
print fib(10);
print "Fib(15):";
print fib(15);
print "Fib(20):";
print fib(20);

# ================================================================
# БЛОК 2: Функции вызывающие другие функции (цепочки вызовов)
# ================================================================

print "=== БЛОК 2: Цепочки вызовов функций ===";

func square(x) {
    return x * x;
}

func cube(x) {
    return x * square(x);
}

func sum_of_cubes(a, b) {
    return cube(a) + cube(b);
}

func hypotenuse(a, b) {
    return sqrt(square(a) + square(b));
}

print "cube(4):";
print cube(4);

print "sum_of_cubes(3, 4):";
print sum_of_cubes(3, 4);

print "hypotenuse(3, 4):";
print hypotenuse(3, 4);

# Тройная вложенность: hypotenuse использует square, sqrt
print "hypotenuse(5, 12):";
print hypotenuse(5, 12);

# ================================================================
# БЛОК 3: Сложная работа с массивами
# ================================================================

print "=== БЛОК 3: Массивы и алгоритмы ===";

# --- Заполнение массива числами Фибоначчи ---
fib_arr = array(10);
for (i = 0; i < 10; i++) {
    fib_arr[i] = fib(i);
}
print "Массив Фибоначчи:";
print fib_arr;

# --- Сумма элементов массива ---
func array_sum(arr_size) {
    total = 0;
    for (i = 0; i < arr_size; i++) {
        total += fib_arr[i];
    }
    return total;
}

print "Сумма массива Фибоначчи:";
print array_sum(10);

# --- Bubble sort (сортировка пузырьком) ---
sort_arr = array(8);
sort_arr[0] = 64;
sort_arr[1] = 34;
sort_arr[2] = 25;
sort_arr[3] = 12;
sort_arr[4] = 22;
sort_arr[5] = 11;
sort_arr[6] = 90;
sort_arr[7] = 1;

print "До сортировки:";
print sort_arr;

size = 8;
for (i = 0; i < size; i++) {
    for (j = 0; j < size - 1; j++) {
        if (sort_arr[j] > sort_arr[j + 1]) {
            temp = sort_arr[j];
            sort_arr[j] = sort_arr[j + 1];
            sort_arr[j + 1] = temp;
        }
    }
}

print "После сортировки:";
print sort_arr;

# --- Поиск максимума и минимума ---
func find_max(arr_size) {
    max_val = sort_arr[0];
    for (i = 1; i < arr_size; i++) {
        if (sort_arr[i] > max_val) {
            max_val = sort_arr[i];
        }
    }
    return max_val;
}

func find_min(arr_size) {
    min_val = sort_arr[0];
    for (i = 1; i < arr_size; i++) {
        if (sort_arr[i] < min_val) {
            min_val = sort_arr[i];
        }
    }
    return min_val;
}

print "Max:";
print find_max(8);
print "Min:";
print find_min(8);

# ================================================================
# БЛОК 4: Математические вычисления высокой точности
# ================================================================

print "=== БЛОК 4: Точные вычисления ===";

# --- Приближение числа e через ряд (e = sum 1/n!) ---
func factorial(n) {
    result = 1;
    for (i = 1; i <= n; i++) {
        result = result * i;
    }
    return result;
}

e_approx = 0;
for (i = 0; i <= 10; i++) {
    e_approx += 1 / factorial(i);
}
print "Приближение e (11 членов):";
print e_approx;
print "Встроенное e:";
print e;

# --- Приближение pi через ряд Лейбница ---
# pi/4 = 1 - 1/3 + 1/5 - 1/7 + ...
pi_approx = 0;
sign = 1;
for (i = 0; i < 1000; i++) {
    pi_approx += sign / (2 * i + 1);
    sign = sign * -1;
}
pi_approx = pi_approx * 4;
print "Приближение pi (1000 итераций):";
print pi_approx;
print "Встроенное pi:";
print pi;

# --- Степенной ряд для sin(x) ---
# sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...
func my_sin(x) {
    result = 0;
    sign = 1;
    for (i = 0; i < 8; i++) {
        power = 2 * i + 1;
        # Вычисляем x^power
        x_pow = 1;
        for (j = 0; j < power; j++) {
            x_pow = x_pow * x;
        }
        result += sign * x_pow / factorial(power);
        sign = sign * -1;
    }
    return result;
}

print "my_sin(pi/6) ~ 0.5:";
print my_sin(pi / 6);
print "sin(pi/6) встроенный:";
print sin(pi / 6);

print "my_sin(pi/2) ~ 1:";
print my_sin(pi / 2);

