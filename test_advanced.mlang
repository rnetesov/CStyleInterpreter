# ================================================================
# БЛОК 8: Итоговый алгоритм — решето Эратосфена (простые до 50)
# ================================================================

print "=== БЛОК 8: Решето Эратосфена ===";

# Массив-флаги: 1 = простое, 0 = составное
sieve_size = 50;
sieve = array(50);

# Инициализация: все числа от 2 помечены как простые
for (i = 0; i < sieve_size; i++) {
    sieve[i] = 1;
}
sieve[0] = 0;
sieve[1] = 0;

# Просеивание
for (i = 2; i * i < sieve_size; i++) {
    if (sieve[i] == 1) {
        # Помечаем все кратные i как составные
        j = i * i;
        while (j < sieve_size) {
            sieve[j] = 0;
            j += i;
        }
    }
}

# Вывод простых чисел
print "Простые числа до 50:";
for (i = 2; i < sieve_size; i++) {
    if (sieve[i] == 1) {
        print i;
    }
}

