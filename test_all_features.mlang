# ---- ТЕСТ 31: Числа Фибоначчи ----
print "=== ТЕСТ 31: Числа Фибоначчи ===";
fib_a = 0;
fib_b = 1;
for (i = 0; i < 10; i++) {
    print fib_a;
    fib_temp = fib_a + fib_b;
    fib_a = fib_b;
    fib_b = fib_temp;
}

# ---- ТЕСТ 32: Массив и функция вместе ----
print "=== ТЕСТ 32: Массив + функция ===";
data = array(5);
for (i = 0; i < 5; i++) {
    data[i] = factorial(i + 1);
}
print data;

